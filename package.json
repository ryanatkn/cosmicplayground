  "description": "tools and toys for expanding minds 🌌",
  "license": "AGPL-3.0-only",
  "homepage": "https://www.cosmicplayground.org",
  "type": "module",
  "scripts": {
    "start": "gro dev",
    "build": "NODE_ENV=production gro build",
    "buildDev": "NODE_ENV=development gro build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ryanatkn/cosmicplayground.git"
  },
  "bugs": {
    "url": "https://github.com/ryanatkn/cosmicplayground/issues"
  },
  "keywords": [
    "space",
    "web",
    "svelte"
  ],
  "author": {
    "name": "Ryan Atkinson",
    "email": "mail@ryanatkn.com",
    "url": "https://www.ryanatkn.com"
  },
  "engines": {
    "node": ">=14"
  },
  "devDependencies": {
    "@feltcoop/gro": "file:../gro",
    "@types/css-tree": "^1.0.0",
    "css-tree": "^1.0.0-alpha22",
    "pixi.js": "^5.3.3",
    "rollup": "^2.30.0",
    "sourcemap-codec": "^1.4.8",
    "svelte": "^3.29.0"
  },
  "dependencies": {},
  "prettier": {
    "useTabs": true,
    "printWidth": 100,
    "singleQuote": true,
    "trailingComma": "all",
    "bracketSpacing": false,
    "svelteSortOrder": "scripts-markup-styles",
    "svelteBracketNewLine": true,
    "overrides": [
      {
        "files": "*.json",
        "options": {
          "useTabs": false
        }
      }
    ]
  }
